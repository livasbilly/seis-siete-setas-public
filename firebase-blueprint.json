{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores player information and statistics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "easy": {
              "type": "object",
              "properties": {
                "setas": { "type": "integer" },
                "points": { "type": "integer" }
              }
            },
            "normal": {
              "type": "object",
              "properties": {
                "setas": { "type": "integer" },
                "points": { "type": "integer" }
              }
            },
            "hard": {
              "type": "object",
              "properties": {
                "setas": { "type": "integer" },
                "points": { "type": "integer" }
              }
            }
          }
        }
      },
      "required": ["uid", "displayName"]
    },
    "Username": {
      "title": "Username Mapping",
      "description": "Used to check for username availability.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/players_v1/{uid}": {
      "schema": "User",
      "description": "User profile and stats."
    },
    "/usernames/{username}": {
      "schema": "Username",
      "description": "Mapping of usernames to UIDs for availability checks."
    }
  }
}
